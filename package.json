{
  "name": "vue-jsx-monorepo",
  "version": "1.2.2",
  "private": true,
  "packageManager": "pnpm@9.4.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -C packages/jsx-explorer run dev",
