{
  "name": "vue-jsx-monorepo",
  "type": "module",
  "version": "2.0.1",
  "private": true,
  "packageManager": "pnpm@11.0.3",
  "license": "MIT",
  "keywords": [
    "vue",
    "jsx"
  ],
  "scripts": {
    "dev": "pnpm -C packages/jsx-explorer run dev",
    "build": "tsdown",
    "build:playground": "pnpm -C packages/jsx-explorer build",
    "test": "vitest",
    "lint": "eslint --cache .",
    "format": "prettier --write .",
    "typecheck": "tsgo",
    "release": "bumpp -r"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@babel/plugin-syntax-typescript": "catalog:",
    "@rollup/plugin-babel": "catalog:",
    "@sxzz/eslint-config": "catalog:",
    "@sxzz/prettier-config": "catalog:",
    "@types/babel__core": "catalog:",
    "@types/babel__helper-module-imports": "catalog:",
    "@types/babel__helper-plugin-utils": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vue/babel-plugin-jsx": "workspace:*",
    "bumpp": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@sxzz/prettier-config"
}
