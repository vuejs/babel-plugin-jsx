    "@types/babel__helper-plugin-utils": "^7.10.3",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260501.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/babel-plugin-jsx": "workspace:*",
    "bumpp": "^11.0.1",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "prettier": "3.8.3",
    "tsdown": "^0.21.10",
    "tslib": "^2.8.1",
